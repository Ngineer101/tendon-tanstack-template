# Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Stripe test-mode configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_CREDITS_1000_PRICE_ID=
STRIPE_CREDITS_5000_PRICE_ID=
STRIPE_CREDITS_20000_PRICE_ID=

# Optional: enable Stripe Tax after configuring it in the Dashboard.
STRIPE_TAX_ENABLED=false

# MCP server feature
# 32-byte key, base64-encoded, used for AES-GCM encryption of stored OAuth
# tokens. Generate one locally with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# In production set via: pnpm exec wrangler secret put MCP_ENCRYPTION_KEY
MCP_ENCRYPTION_KEY=
# Set to "true" only in local dev to allow http:// and localhost MCP servers.
MCP_ALLOW_INSECURE_HTTP=false
