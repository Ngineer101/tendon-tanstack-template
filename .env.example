# Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Stripe test-mode configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_CREDITS_1000_PRICE_ID=
STRIPE_CREDITS_5000_PRICE_ID=
STRIPE_CREDITS_20000_PRICE_ID=

# Optional: enable Stripe Tax after configuring it in the Dashboard.
STRIPE_TAX_ENABLED=false

# MCP OAuth and token storage.
# Generate at least 32 random bytes and store this with the platform secret manager.
# Register the client ID (and optional secret) with each MCP authorization server.
MCP_AUTH_ENCRYPTION_KEY=
MCP_OAUTH_CLIENT_ID=
MCP_OAUTH_CLIENT_SECRET=
