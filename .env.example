# Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Stripe test-mode configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_CREDITS_1000_PRICE_ID=
STRIPE_CREDITS_5000_PRICE_ID=
STRIPE_CREDITS_20000_PRICE_ID=

# Optional: enable Stripe Tax after configuring it in the Dashboard.
STRIPE_TAX_ENABLED=false

# MCP server connections
# Encrypts MCP OAuth tokens at rest. Generate with: openssl rand -base64 32
# In production, set as a Worker secret: wrangler secret put MCP_TOKEN_ENCRYPTION_KEY
MCP_TOKEN_ENCRYPTION_KEY=

# Development only: allow connecting MCP servers on localhost/private networks.
# Never enable in production.
MCP_ALLOW_PRIVATE_NETWORK=false
